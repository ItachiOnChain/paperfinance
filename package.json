{
    "name": "hypaper-0g",
    "version": "0.1.0",
    "private": true,
    "description": "Paper trading system on 0G EVM — multi-chain abstraction over HyPaper",
    "type": "module",
    "license": "MIT",
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "dev": "bun run --filter @hypaper/engine dev",
        "build": "bun run --filter '*' build",
        "check-env": "bun run scripts/check-env.ts",
        "test": "bun run --filter '*' test",
        "docker:up": "docker compose up -d redis postgres",
        "docker:down": "docker compose down"
    },
    "devDependencies": {
        "bun-types": "^1.1.0",
        "typescript": "^5.7.3"
    }
}