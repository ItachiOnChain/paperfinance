# ─── 0G Chain ───────────────────────────────────────────────
OG_RPC_URL=
OG_WS_RPC_URL=
OG_CHAIN_ID=16661

# ─── Market Data ────────────────────────────────────────────
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# ─── Data Stores ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://hypaper:hypaper@localhost:5432/hypaper

# ─── Auth / Security ───────────────────────────────────────
JWT_SECRET=
DEPLOYER_PK=
VAULT_ADDRESS=

# ─── Server ─────────────────────────────────────────────────
PORT=3000
DEFAULT_BALANCE=100000
LOG_LEVEL=info

# ─── WebSocket Reconnect (ms) ──────────────────────────────
WS_RECONNECT_MIN_MS=1000
WS_RECONNECT_MAX_MS=30000

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# ─── Fee Config ─────────────────────────────────────────────
FEES_ENABLED=true
FEE_RATE_TAKER=0.00035
FEE_RATE_MAKER=0.0001
FUNDING_ENABLED=true
FUNDING_INTERVAL_MS=28800000
